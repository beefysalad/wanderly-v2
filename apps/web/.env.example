# Next.js frontend environment example
# Copy to apps/web/.env.local for local frontend development.

# Browser-facing API URL. This must be public because it is used by client-side code.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Clerk authentication keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Optional: disable Next telemetry locally/inside containers.
NEXT_TELEMETRY_DISABLED=1
