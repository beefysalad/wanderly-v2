# NestJS API environment example
# Copy to apps/api/.env for local backend development.

NODE_ENV=development
PORT=3001

# Prisma database connection string.
# For direct local API development from your host machine, use localhost and the exposed Docker port 5433.
# Inside Docker Compose, the API receives a DATABASE_URL that uses postgres:5432.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nexion_monorepo?schema=public"

# Comma-separated list of allowed browser origins for CORS when enabled.
CORS_ORIGIN=http://localhost:3000

# Set to true only when the API runs behind a trusted proxy/load balancer that
# sets X-Forwarded-For. Required for accurate IP-based rate limiting in hosted
# environments.
TRUST_PROXY=false

# Global API rate limit applied by @nestjs/throttler.
# TTL values are in milliseconds.
API_RATE_LIMIT_MAX_REQUESTS=120
API_RATE_LIMIT_TTL_MS=60000

# Stricter limit for the authenticated user self-sync fallback endpoint.
API_USER_SYNC_RATE_LIMIT_MAX_REQUESTS=20
API_USER_SYNC_RATE_LIMIT_TTL_MS=60000

# Clerk can legitimately retry webhooks, so this endpoint is explicit and
# separate from the global default.
API_CLERK_WEBHOOK_RATE_LIMIT_MAX_REQUESTS=60
API_CLERK_WEBHOOK_RATE_LIMIT_TTL_MS=60000

# Clerk server-side secret key. Keep this backend-only.
CLERK_SECRET_KEY=sk_test_replace_me

# Clerk webhook signing secret from the Clerk dashboard endpoint settings.
CLERK_WEBHOOK_SECRET=whsec_replace_me
