# Mobile environment variables
# Copy to .env.local for local development.
# All browser/native-exposed vars must be prefixed with EXPO_PUBLIC_.

# API base URL. Use http://localhost:3001 for iOS sim.
# For Android emulator use http://10.0.2.2:3001.
# For physical device use your LAN IP, e.g. http://192.168.x.x:3001.
EXPO_PUBLIC_API_URL=http://localhost:3001

# Clerk publishable key — get this from clerk.com dashboard (same project as web).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
