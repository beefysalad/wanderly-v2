# Mobile environment variables
# Copy to .env.local for local development.
# All browser/native-exposed vars must be prefixed with EXPO_PUBLIC_.
#
# EAS preview/production builds should define these same variable names in
# EAS environment settings. Do not commit real environment-specific values.

# API base URL.
#
# Local development:
# - iOS simulator: http://localhost:3001
# - Android emulator: http://10.0.2.2:3001
# - Physical device: use your LAN IP, e.g. http://192.168.x.x:3001
#
# Preview/production builds:
# - Must point to a deployed HTTPS API URL.
# - Must not use localhost, 10.0.2.2, or a LAN IP.
# - Example shape only: https://api.example.com
EXPO_PUBLIC_API_URL=http://localhost:3001

# Clerk publishable key. Use the key for the matching Clerk environment:
# - Local/preview builds generally use the Clerk development environment.
# - Production builds must use the Clerk production environment.
# - This is public-safe by design, but still environment-specific.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
