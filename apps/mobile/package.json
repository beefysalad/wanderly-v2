  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "echo 'Use explicit EAS scripts, e.g. npm run eas:build:preview:android -w mobile'",
    "eas:build:development:android": "eas build --profile development --platform android",
    "eas:build:development:ios": "eas build --profile development --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:production": "eas build --profile production --platform all",
    "eas:submit:production:android": "eas submit --profile production --platform android",
    "eas:submit:production:ios": "eas submit --profile production --platform ios",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "reset-project": "node ./scripts/reset-project.js"
  },
  "private": true
}
