# Root environment example
# Copy to .env only if you want to override Docker Compose defaults.
# App runtime env files live in apps/web/.env.local and apps/api/.env.

COMPOSE_PROJECT_NAME=nexion-monorepo

# Host ports used by docker-compose.yml
WEB_PORT=3000
API_PORT=3001
POSTGRES_PORT=5433

# Internal container port for the NestJS API when running Docker Compose.
# Local host-run API development should use apps/api/.env with PORT=3001.
API_INTERNAL_PORT=3000

# Browser-facing API URL used by the Next.js app
NEXT_PUBLIC_API_URL=http://localhost:3001

# Local Docker Postgres defaults
POSTGRES_DB=nexion_monorepo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Optional override for the API container database URL.
# Usually leave this commented out. Docker Compose builds this from the Postgres values above.
# Use the Docker service hostname `postgres` and internal port `5432` here.
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/nexion_monorepo?schema=public
